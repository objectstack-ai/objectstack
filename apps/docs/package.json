{
  "name": "@objectstack/docs",
  "version": "4.2.1",
  "private": true,
  "description": "ObjectStack Protocol Documentation Site",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm --filter @objectstack/spec gen:schema && pnpm --filter @objectstack/spec gen:docs && NODE_OPTIONS='--max-old-space-size=4096' next build",
    "site:start": "next start",
    "site:lint": "next lint",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "fumadocs-core": "16.11.5",
    "fumadocs-mdx": "15.2.0",
    "fumadocs-ui": "16.11.5",
    "lucide-react": "^1.25.0",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@objectstack/spec": "workspace:*",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/mdx": "^2.0.14",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "negotiator": "^1.0.0",
    "postcss": "^8.5.20",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
