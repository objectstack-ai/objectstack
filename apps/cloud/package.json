{
  "name": "@objectstack/cloud",
  "version": "4.0.5",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "PORT=${PORT:-4000} OS_DISABLE_CONSOLE=1 objectstack dev",
    "build": "tsup",
    "start": "PORT=${PORT:-4000} OS_DISABLE_CONSOLE=1 objectstack serve dist/objectstack.config.js --prebuilt",
    "doctor": "objectstack doctor",
    "typecheck": "tsc --noEmit",
    "test": "objectstack test",
    "test:production-flow": "tsx test/production-flow.test.ts",
    "cf:build": "bash scripts/deploy-cloudflare.sh --skip-push --skip-deploy",
    "cf:push": "bash scripts/deploy-cloudflare.sh --skip-build --skip-deploy",
    "cf:deploy": "bash scripts/deploy-cloudflare.sh",
    "cf:deploy:dry": "bash scripts/deploy-cloudflare.sh --dry-run",
    "cf:secrets": "bash scripts/setup-cloudflare-secrets.sh",
    "cf:tail": "wrangler tail --config wrangler.toml",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@libsql/client": "^0.17.3",
    "@objectstack/driver-memory": "workspace:*",
    "@objectstack/driver-sql": "workspace:*",
    "@objectstack/driver-turso": "workspace:*",
    "@objectstack/hono": "workspace:*",
    "@objectstack/metadata": "workspace:*",
    "@objectstack/objectql": "workspace:*",
    "@objectstack/plugin-audit": "workspace:*",
    "@objectstack/plugin-auth": "workspace:*",
    "@objectstack/plugin-hono-server": "workspace:*",
    "@objectstack/plugin-security": "workspace:*",
    "@objectstack/runtime": "workspace:*",
    "@objectstack/service-ai": "workspace:*",
    "@objectstack/service-analytics": "workspace:*",
    "@objectstack/service-automation": "workspace:*",
    "@objectstack/service-cloud": "workspace:*",
    "@objectstack/service-feed": "workspace:*",
    "@objectstack/service-package": "workspace:*",
    "@objectstack/service-tenant": "workspace:*",
    "@objectstack/spec": "workspace:*",
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@cloudflare/containers": "^0.3.3",
    "@cloudflare/workers-types": "^4.20260510.1",
    "@objectstack/cli": "workspace:*",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.90.0"
  }
}
