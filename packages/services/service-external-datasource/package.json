    "vitest": "^4.1.7"
  },
  "keywords": [
    "objectstack",
    "service",
    "external-datasource",
    "federation",
    "introspection"
  ],
  "author": "ObjectStack",
  "repository": {
    "type": "git",
    "url": "https://github.com/objectstack-ai/framework.git",
    "directory": "packages/services/service-external-datasource"
  },
  "homepage": "https://objectstack.ai/docs",
  "bugs": "https://github.com/objectstack-ai/framework/issues",
  "publishConfig": {
    "access": "public"
  }
