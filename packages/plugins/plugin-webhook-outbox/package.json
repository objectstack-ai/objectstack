      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@objectstack/core": "workspace:*",
    "@objectstack/spec": "workspace:*",
    "@objectstack/service-cluster": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "keywords": ["objectstack", "plugin", "webhook", "outbox", "cluster"],
  "author": "ObjectStack",
  "repository": {
    "type": "git",
    "url": "https://github.com/objectstack-ai/framework.git",
    "directory": "packages/plugins/plugin-webhook-outbox"
  }
