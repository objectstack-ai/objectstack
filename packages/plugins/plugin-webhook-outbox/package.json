{
  "name": "@objectstack/plugin-webhook-outbox",
  "version": "5.1.0",
  "license": "Apache-2.0",
  "description": "Persistent, cluster-aware webhook outbox + dispatcher. Implements the durable delivery pipeline described in content/docs/concepts/webhook-delivery.mdx.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
