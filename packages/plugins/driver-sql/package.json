{
  "name": "@objectstack/driver-sql",
  "version": "11.5.0",
  "license": "Apache-2.0",
  "description": "SQL Driver for ObjectStack - Supports PostgreSQL, MySQL, SQLite via Knex",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config ../../../tsup.config.ts",
    "dev": "tsc -w",
    "test": "vitest run"
  },
  "dependencies": {
    "@objectstack/core": "workspace:*",
    "@objectstack/spec": "workspace:*",
    "@objectstack/types": "workspace:*",
    "knex": "^3.3.0",
    "nanoid": "^5.1.16"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "peerDependencies": {
    "mysql2": "^3.0.0",
    "pg": "^8.0.0",
    "sqlite3": "^5.0.0",
    "tedious": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "sqlite3": {
      "optional": true
    },
    "tedious": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "better-sqlite3": "^12.11.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "objectstack",
    "driver",
    "sql",
    "postgres",
    "mysql",
    "sqlite"
  ],
  "author": "ObjectStack",
  "repository": {
    "type": "git",
    "url": "https://github.com/objectstack-ai/framework.git",
    "directory": "packages/plugins/driver-sql"
  },
  "homepage": "https://objectstack.ai/docs",
  "bugs": "https://github.com/objectstack-ai/framework/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
