  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "objectstack",
    "plugin",
    "approval",
    "workflow",
    "process"
