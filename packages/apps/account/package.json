{
  "name": "@objectstack/account",
  "version": "12.2.0",
  "license": "Apache-2.0",
  "description": "ObjectStack Account — the end-user account/self-service console app, packaged as its own ObjectStack app package (ADR-0048: one app per package).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@objectstack/platform-objects": "workspace:*",
    "@objectstack/spec": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "objectstack",
    "app",
    "account"
  ],
  "author": "ObjectStack",
  "repository": {
    "type": "git",
    "url": "https://github.com/objectstack-ai/framework.git",
    "directory": "packages/apps/account"
  },
  "homepage": "https://objectstack.ai/docs",
  "bugs": "https://github.com/objectstack-ai/framework/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
