{
  "name": "@objectstack/example-crm",
  "version": "4.0.60",
  "description": "Minimal CRM example — a smoke-test workspace that exercises the metadata loading pipeline (objects → views → app → dashboard → hook → flow → seed). For a full-featured enterprise CRM see https://github.com/objectstack-ai/hotcrm.",
  "license": "Apache-2.0",
  "private": true,
  "main": "./objectstack.config.ts",
  "types": "./objectstack.config.ts",
  "exports": {
    ".": "./objectstack.config.ts",
    "./objectstack.config": "./objectstack.config.ts"
  },
  "scripts": {
    "dev": "objectstack dev",
    "start": "objectstack start",
    "build": "objectstack build",
    "validate": "objectstack validate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@objectstack/runtime": "workspace:*",
    "@objectstack/spec": "workspace:*"
  },
  "devDependencies": {
    "@objectstack/cli": "workspace:*",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
